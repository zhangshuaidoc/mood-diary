/* app.wxss - 全局样式 */

/* 主题色变量 */
page {
  --primary-color: #6BCB77;
  --secondary-color: #FFD93D;
  --background-color: #F7F7F7;
  --text-color: #333333;
  --text-secondary: #999999;
  --border-color: #E5E5E5;
  --card-bg: #FFFFFF;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text-color);
  background-color: var(--background-color);
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 标题样式 */
.title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
  margin-bottom: 24rpx;
}

/* 按钮样式 */
.btn-primary {
  background-color: var(--primary-color);
  color: #FFFFFF;
  border: none;
  border-radius: 24rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background-color: #FFFFFF;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: 24rpx;
  padding: 22rpx 46rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 文字辅助类 */
.text-secondary {
  color: var(--text-secondary);
  font-size: 24rpx;
}

.text-center {
  text-align: center;
}

.text-bold {
  font-weight: bold;
}

/* Flex布局辅助类 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-wrap {
  flex-wrap: wrap;
}

/* 间距辅助类 */
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: 24rpx 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
  color: var(--text-secondary);
}

.empty-state .emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-state .text {
  font-size: 28rpx;
}
