/* pages/calendar/calendar.wxss */

.container {
  padding: 24rpx;
  min-height: 100vh;
  background: #F7F7F7;
}

/* 月份头部 */
.month-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.month-nav {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F7F7F7;
}

.nav-icon {
  font-size: 40rpx;
  color: #6BCB77;
  font-weight: bold;
}

.month-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 星期头部 */
.week-header {
  display: flex;
  padding: 16rpx 0;
  margin-bottom: 8rpx;
}

.week-item {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

/* 日历网格 */
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.day-item {
  width: 14.28%;
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.day-item.empty {
  opacity: 0;
}

.day-content {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  position: relative;
}

.day-item.today .day-content {
  border: 3rpx solid #6BCB77;
}

.day-item.selected .day-content {
  background: rgba(107, 203, 119, 0.2);
}

.day-number {
  font-size: 28rpx;
  color: #333;
}

.day-emoji {
  font-size: 40rpx;
}

.today-dot {
  position: absolute;
  bottom: 4rpx;
  width: 8rpx;
  height: 8rpx;
  background: #6BCB77;
  border-radius: 50%;
}

/* 详情弹窗 */
.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.detail-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 32rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.detail-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.detail-emoji {
  font-size: 80rpx;
  margin-right: 24rpx;
}

.detail-info {
  flex: 1;
}

.detail-mood {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.detail-date {
  font-size: 24rpx;
  color: #999;
}

.detail-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  padding: 24rpx;
  background: #F7F7F7;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.detail-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.detail-actions {
  display: flex;
  gap: 24rpx;
}

.btn-action {
  flex: 1;
  border-radius: 48rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.btn-edit {
  background: #6BCB77;
  color: #FFFFFF;
  border: none;
}

.btn-delete {
  background: #FFFFFF;
  color: #FF6B6B;
  border: 2rpx solid #FF6B6B;
}
