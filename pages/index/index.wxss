/* pages/index/index.wxss */

.container {
  padding: 32rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F7F7F7 30%);
}

/* 日期区域 */
.date-section {
  text-align: center;
  padding: 40rpx 0;
}

.date-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.date-hint {
  font-size: 28rpx;
  color: #6BCB77;
}

/* 已记录状态 */
.recorded-section {
  padding: 0 16rpx;
}

.recorded-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(107, 203, 119, 0.15);
}

.recorded-emoji {
  font-size: 96rpx;
  margin-right: 32rpx;
}

.recorded-info {
  flex: 1;
}

.recorded-mood-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.recorded-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.recorded-time {
  font-size: 24rpx;
  color: #999;
}

.action-buttons {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.btn-edit {
  flex: 1;
  background: #6BCB77;
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.btn-delete {
  flex: 1;
  background: #FFFFFF;
  color: #FF6B6B;
  border: 2rpx solid #FF6B6B;
  border-radius: 48rpx;
  padding: 22rpx;
  font-size: 28rpx;
}

/* 编辑区域 */
.edit-section {
  padding: 0 16rpx;
}

/* 心情选择器 */
.mood-picker {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.mood-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
  text-align: center;
}

.mood-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.mood-item {
  width: 23%;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  transition: all 0.3s ease;
  border: 3rpx solid transparent;
}

.mood-item.selected {
  background: var(--mood-color);
  transform: scale(1.05);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.mood-item.selected .mood-name {
  color: #FFFFFF;
}

.mood-emoji {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.mood-name {
  font-size: 24rpx;
  color: #666;
}

/* 文字输入 */
.text-input-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.text-input-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.text-input-title {
  font-size: 28rpx;
  color: #666;
}

.text-counter {
  font-size: 24rpx;
  color: #999;
}

.text-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  padding: 16rpx;
  background: #F7F7F7;
  border-radius: 12rpx;
  box-sizing: border-box;
}

/* 按钮 */
.btn-save {
  width: 100%;
  background: linear-gradient(135deg, #6BCB77 0%, #4CAF50 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(107, 203, 119, 0.3);
}

.btn-save:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-cancel {
  width: 100%;
  background: #FFFFFF;
  color: #999;
  border: 2rpx solid #E5E5E5;
  border-radius: 48rpx;
  padding: 26rpx;
  font-size: 28rpx;
  margin-top: 16rpx;
}
